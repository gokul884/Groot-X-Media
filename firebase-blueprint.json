{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Leads captured from various forms on the website",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the lead",
          "maxLength": 128
        },
        "name": {
          "type": "string",
          "description": "The full name of the lead",
          "maxLength": 128
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the lead",
          "maxLength": 30
        },
        "website": {
          "type": "string",
          "description": "The website of the lead",
          "maxLength": 200
        },
        "plan": {
          "type": "string",
          "description": "The selected plan",
          "maxLength": 50
        },
        "message": {
          "type": "string",
          "description": "The message sent by the lead",
          "maxLength": 1000
        },
        "source": {
          "type": "string",
          "description": "Where the lead was captured (e.g., contact_page, homepage_hero, exit_intent_audit)",
          "maxLength": 50
        },
        "status": {
          "type": "string",
          "description": "The status of the lead",
          "maxLength": 50
        },
        "timestamp": {
          "type": "object",
          "description": "Server timestamp of creation"
        }
      },
      "required": ["email", "source", "status"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of captured leads and inquiries"
    }
  }
}
